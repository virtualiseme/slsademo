# Copy to .env before running docker compose.
# Values shown are the defaults — only change what you need.

# ── LLM model pulled by model-init ──────────────────────────────────────────
# CPU-friendly small models (recommended for laptops / dev machines):
#   phi3:mini      (~2.3 GB)  — Microsoft Phi-3, good balance of speed/quality
#   llama3.2:1b    (~1.3 GB)  — smallest usable Llama 3.2
#   qwen2.5:0.5b   (~394 MB)  — tiny but surprisingly capable
#   tinyllama      (~637 MB)  — fast, limited reasoning
#
# GPU models (use docker-compose.gpu.yml):
#   llama3.2:8b    (~5 GB)    — strong general-purpose model
#   mistral:7b     (~4.1 GB)  — excellent instruction following
OLLAMA_MODEL=phi3:mini

# ── Port mappings ────────────────────────────────────────────────────────────
OLLAMA_PORT=11434
WEBUI_PORT=3000
SENTIMENT_PORT=8000

# ── Open WebUI branding ──────────────────────────────────────────────────────
WEBUI_NAME=Chainguard AI Demo

# ── Image naming ─────────────────────────────────────────────────────────────
PROJECT_NAME=chainguard-demo
